# Copy this file to ".env" and fill in real values. The .env file is gitignored.
DB_URL=jdbc:postgresql://localhost:5432/isappdb
DB_USERNAME=postgres
DB_PASSWORD=changeme

# Base64-encoded HS256 signing key for JWTs. Must decode to >= 32 bytes.
# Generate one with:  openssl rand -base64 32
JWT_KEY=replace-with-a-base64-encoded-256-bit-key
